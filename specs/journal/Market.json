{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Market",
	"description": "Station commodity market data - written to Market.json",
	"type": "object",
	"required": [
		"timestamp",
		"event",
		"MarketID",
		"StationName",
		"StationType",
		"StarSystem",
		"Items"
	],
	"properties": {
		"timestamp": { "type": "string", "format": "date-time" },
		"event": { "type": "string", "enum": ["Market"] },
		"MarketID": { "type": "integer" },
		"StationName": { "type": "string" },
		"StationType": { "type": "string" },
		"StarSystem": { "type": "string" },
		"SystemAddress": { "type": "integer" },
		"CarrierDockingAccess": { "type": "string" },
		"Items": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"Name": { "type": "string" },
					"Name_Localised": { "type": "string" },
					"BuyPrice": { "type": "integer" },
					"SellPrice": { "type": "integer" },
					"MeanPrice": { "type": "integer" },
					"StockBracket": { "type": "integer" },
					"DemandBracket": { "type": "integer" },
					"Stock": { "type": "integer" },
					"Demand": { "type": "integer" },
					"StatusFlags": { "type": "string" }
				}
			}
		}
	}
}
