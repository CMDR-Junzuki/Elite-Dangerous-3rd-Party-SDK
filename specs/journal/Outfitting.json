{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Outfitting",
	"description": "Station outfitting module listing - written to Outfitting.json",
	"type": "object",
	"required": [
		"timestamp",
		"event",
		"MarketID",
		"StationName",
		"StarSystem",
		"Items"
	],
	"properties": {
		"timestamp": { "type": "string", "format": "date-time" },
		"event": { "type": "string", "enum": ["Outfitting"] },
		"MarketID": { "type": "integer" },
		"StationName": { "type": "string" },
		"StarSystem": { "type": "string" },
		"SystemAddress": { "type": "integer" },
		"Items": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"id": { "type": "integer" },
					"Name": { "type": "string" },
					"Name_Localised": { "type": "string" },
					"BuyPrice": { "type": "integer" }
				}
			}
		}
	}
}
