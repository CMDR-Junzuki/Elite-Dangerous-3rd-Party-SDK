{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "JournalEvent",
	"description": "Base schema for all Elite Dangerous journal events",
	"type": "object",
	"required": ["timestamp", "event"],
	"properties": {
		"timestamp": {
			"type": "string",
			"format": "date-time",
			"description": "ISO 8601 timestamp of the event"
		},
		"event": { "type": "string", "description": "Event type name" },
		"horizons": {
			"type": "boolean",
			"description": "Whether the player owns Horizons"
		},
		"odyssey": {
			"type": "boolean",
			"description": "Whether the player owns Odyssey"
		},
		"Taxoname": {
			"type": "string",
			"description": "The player's taxoname (anonymised name)"
		}
	}
}
