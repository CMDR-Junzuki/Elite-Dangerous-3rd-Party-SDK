{
	"description": "Micro resources transferred between ship/backpack",
	"properties": {
		"timestamp": {
			"type": "string",
			"format": "date-time"
		},
		"Transfers": {
			"items": {
				"properties": {
					"Direction": {
						"type": "string",
						"enum": ["ToBackpack", "ToShipLocker"]
					},
					"Name_Localised": {
						"type": "string"
					},
					"Name": {
						"type": "string"
					},
					"Count": {
						"type": "integer"
					}
				},
				"type": "object"
			},
			"type": "array"
		},
		"event": {
			"type": "string",
			"enum": ["TransferMicroResources"]
		}
	},
	"type": "object",
	"required": ["timestamp", "event"],
	"title": "TransferMicroResources",
	"$schema": "http://json-schema.org/draft-07/schema#"
}
