{
	"description": "Signals found after detailed surface scan",
	"properties": {
		"BodyID": {
			"type": "integer",
			"description": "Body ID"
		},
		"BodyName": {
			"type": "string"
		},
		"event": {
			"type": "string",
			"enum": ["SAASignalsFound"]
		},
		"Signals": {
			"items": {
				"properties": {
					"Count": {
						"type": "integer"
					},
					"Type_Localised": {
						"type": "string"
					},
					"Type": {
						"type": "string"
					}
				},
				"type": "object"
			},
			"type": "array"
		},
		"SystemAddress": {
			"type": "integer",
			"description": "Unique system 64-bit ID"
		},
		"Genuses": {
			"items": {
				"properties": {
					"Genus_Localised": {
						"type": "string"
					},
					"Genus": {
						"type": "string"
					}
				},
				"type": "object"
			},
			"type": "array"
		},
		"timestamp": {
			"type": "string",
			"format": "date-time"
		}
	},
	"type": "object",
	"required": ["timestamp", "event"],
	"title": "SAASignalsFound",
	"$schema": "http://json-schema.org/draft-07/schema#"
}
