{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Cargo",
	"description": "Ship cargo manifest - written to Cargo.json and updated on changes",
	"type": "object",
	"required": ["timestamp", "event", "Inventory", "Vessel"],
	"properties": {
		"timestamp": { "type": "string", "format": "date-time" },
		"event": { "type": "string", "enum": ["Cargo"] },
		"Vessel": { "type": "string", "enum": ["Ship", "SRV"] },
		"Inventory": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"Name": { "type": "string" },
					"Name_Localised": { "type": "string" },
					"Count": { "type": "integer" },
					"Stolen": { "type": "integer" },
					"MissionID": { "type": "integer" }
				}
			}
		}
	}
}
