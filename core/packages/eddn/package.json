{
	"name": "@elite-dangerous-sdk/eddn",
	"version": "1.0.0",
	"description": "Elite Dangerous Data Network (EDDN) sender and receiver client",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
