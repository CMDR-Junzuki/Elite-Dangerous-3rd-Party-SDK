{
	"name": "@elite-dangerous-sdk/companion",
	"version": "1.0.0",
	"description": "Elite Dangerous Companion API (CAPI) client with oAuth2 PKCE auth",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/ __tests__/"
	},
	"dependencies": {
		"@elite-dangerous-sdk/journal": "1.0.0",
		"@elite-dangerous-sdk/utils": "1.0.0"
	},
	"devDependencies": {
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
	},
	"files": ["dist/", "src/", "README.md"],
}
