{
	"name": "@elite-dangerous-sdk/data",
	"version": "1.0.0",
	"description": "Elite Dangerous game data (FDevIDs, coriolis ship/module/modification data)",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"codegen": "tsx codegen/generate-fdevids.ts && tsx codegen/generate-coriolis.ts",
		"prebuild": "npm run codegen",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/ __tests__/"
	},
	"devDependencies": {
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"vitest": "^2.0.0",
		"@types/node": "^20.0.0"
	},
	"files": ["dist/", "src/", "README.md"],
}
